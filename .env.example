# Copy to .env for local development (gitignored). start_server.sh sources it.

# Postgres connection. Defaults to the local Docker Postgres if unset.
DATABASE_URL=postgresql://dev:devpass@localhost:5433/iportfolio

# Access token. When set, all API requests must send
# "Authorization: Bearer <API_TOKEN>". Leave unset to disable auth locally.
# API_TOKEN=change-me-to-a-long-random-string
